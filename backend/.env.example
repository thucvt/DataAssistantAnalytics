# File .env runtime do Web Installer tự sinh ra (không chỉnh tay ở production).
# Đây chỉ là mẫu tham khảo các biến hệ thống dùng.

# Đánh dấu đã cài đặt — Installer set "true" sau khi hoàn tất
INSTALLED=false

# Khóa bí mật sinh ngẫu nhiên lúc cài, dùng mã hóa API key trong DB
SECRET_KEY=

# Kết nối DB. Mặc định SQLite fallback:
DATABASE_URL=sqlite:///./data/app.db
# Postgres: postgresql+psycopg://user:pass@host:5432/dbname
# MySQL:    mysql+pymysql://user:pass@host:3306/dbname

LICENSE_KEY=
APP_PORT=8080
DEBUG=false
